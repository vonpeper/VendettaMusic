          "name": "vendetta",
          "appName": "vendetta-prod-gcqoaf",
          "description": "Vendetta Music app (migrated from /opt/vendetta)",
          "env": "MASKED_BY_DIAGNOSTIC_SCRIPT",
          "composeFile": "services:\n  vendetta-app:\n    image: ghcr.io/vonpeper/vendettamusic:${VENDETTA_TAG:-latest}\n    pull_policy: always\n    restart: always\n    mem_limit: 1024m\n    mem_reservation: 256m\n    environment:\n      DATABASE_URL: ${DATABASE_URL}\n      AUTH_SECRET: ${AUTH_SECRET}\n      AUTH_TRUST_HOST: ${AUTH_TRUST_HOST}\n      EVOLUTION_BASE_URL: ${EVOLUTION_BASE_URL}\n      EVOLUTION_API_KEY: ${EVOLUTION_API_KEY}\n      EVOLUTION_INSTANCE: ${EVOLUTION_INSTANCE}\n      EVOLUTION_WEBHOOK_SECRET: ${EVOLUTION_WEBHOOK_SECRET}\n      GOOGLE_CLIENT_ID: ${GOOGLE_CLIENT_ID}\n      GOOGLE_CLIENT_SECRET: ${GOOGLE_CLIENT_SECRET}\n      GOOGLE_REFRESH_TOKEN: ${GOOGLE_REFRESH_TOKEN}\n      GOOGLE_CALENDAR_ID: ${GOOGLE_CALENDAR_ID}\n      GOOGLE_MAPS_API_KEY: ${GOOGLE_MAPS_API_KEY}\n      STRIPE_SECRET_KEY: ${STRIPE_SECRET_KEY}\n      STRIPE_WEBHOOK_SECRET: ${STRIPE_WEBHOOK_SECRET}\n      NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: ${NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY}\n      NEXT_PUBLIC_APP_URL: ${NEXT_PUBLIC_APP_URL}\n      ADMIN_WHATSAPP_NUMBER: ${ADMIN_WHATSAPP_NUMBER}\n      DEFAULT_ORIGIN_ADDRESS: ${DEFAULT_ORIGIN_ADDRESS}\n      FUEL_PRICE_MXN: ${FUEL_PRICE_MXN}\n    volumes:\n      - /opt/vendetta/prisma:/app/prisma\n      - /opt/vendetta/public/assets:/app/public/assets\n      - /opt/vendetta/public/images/uploads:/app/public/images/uploads\n      - /opt/vendetta/public/images/musicians:/app/public/images/musicians\n    networks:\n      - dokploy-network\n    labels:\n      - \"traefik.enable=true\"\n      - \"traefik.docker.network=dokploy-network\"\n      - \"traefik.http.services.vendetta.loadbalancer.server.port=3000\"\n      - \"traefik.http.routers.vendetta-http.rule=Host(`vendetta.mx`) || Host(`www.vendetta.mx`)\"\n      - \"traefik.http.routers.vendetta-http.entrypoints=web\"\n      - \"traefik.http.routers.vendetta-http.middlewares=redirect-to-https\"\n      - \"traefik.http.middlewares.redirect-to-https.redirectscheme.scheme=https\"\n      - \"traefik.http.routers.vendetta.rule=Host(`vendetta.mx`) || Host(`www.vendetta.mx`)\"\n      - \"traefik.http.routers.vendetta.entrypoints=websecure\"\n      - \"traefik.http.routers.vendetta.tls=true\"\n      - \"traefik.http.routers.vendetta.tls.certresolver=letsencrypt\"\n\nnetworks:\n  dokploy-network:\n    external: true\n",
