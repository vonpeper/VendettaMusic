# ────────────────────────────────────────────────
# Vendetta — variables de entorno
# Copiar a .env y completar valores reales en producción.
# ────────────────────────────────────────────────

# DB (SQLite local; usa libsql:// o file: con ruta absoluta en Docker)
DATABASE_URL=file:./prisma/dev.db

# NextAuth
AUTH_SECRET=
NEXT_PUBLIC_APP_URL=https://vendetta.prosuite.pro

# Evolution API v2 (WhatsApp). Pueden venir también desde GlobalConfig.
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=vendetta_admin
EVOLUTION_WEBHOOK_SECRET=

# Número del administrador para notificaciones de nuevas solicitudes (E.164 sin +)
ADMIN_WHATSAPP_NUMBER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google Calendar (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Pre-relleno opcional del WhatsApp del admin en la UI (lado cliente)
NEXT_PUBLIC_ADMIN_WA=
