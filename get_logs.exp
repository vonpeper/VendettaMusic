#!/usr/bin/expect -f
set timeout 60
spawn ssh -o PreferredAuthentications=password -o StrictHostKeyChecking=no panel-prosuite "echo 'zNb+kFF7X8COrbKB' | sudo -S docker compose -f /opt/vendetta/docker-compose.yml logs --tail=100 vendetta-app"
expect {
    "*assword:*" {
        send "zNb+kFF7X8COrbKB\r"
        exp_continue
    }
    eof
}
