#!/usr/bin/expect -f
set timeout 120
spawn ssh -o PreferredAuthentications=password -o StrictHostKeyChecking=no panel-prosuite "echo 'Pp55202104#' | sudo -S docker exec -i vendetta-app /bin/sh -c 'DATABASE_URL=file:/app/prisma/prod.db npx prisma db push --accept-data-loss'"
expect {
    "*assword:*" {
        send "Pp55202104#\r"
        exp_continue
    }
    eof
}
