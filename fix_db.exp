#!/usr/bin/expect -f
set timeout 120
spawn ssh -o PreferredAuthentications=password -o StrictHostKeyChecking=no panel-prosuite "echo 'zNb+kFF7X8COrbKB' | sudo -S docker exec -i vendetta-app npx prisma db push --accept-data-loss"
expect {
    "*assword:*" {
        send "zNb+kFF7X8COrbKB\r"
        exp_continue
    }
    eof
}
