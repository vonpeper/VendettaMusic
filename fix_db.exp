#!/usr/bin/expect -f
set timeout 600
spawn ssh -o PreferredAuthentications=password -o StrictHostKeyChecking=no panel-prosuite "echo 'Pp55202104#' | sudo -S docker exec -u root vendetta-app sh -c 'npm install -g prisma@7.8.0 && prisma db push --accept-data-loss --url file:/app/prisma/prod.db'"
expect {
    "*assword:*" {
        send "Pp55202104#\r"
        exp_continue
    }
    eof
}
